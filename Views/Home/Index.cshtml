@{
    ViewData["Title"] = "Home Page";
}

<div class="row g-4">
    @for (int i = 0; i < ViewBag.CategoriesList.Length; i++){
        var category = ViewBag.CategoriesList[i];
        <div class="col-md-4">
            <div class="card h-100 text-center category-card">
                <div class="card-body">
                    <div class="mb-4">
                        <i class="@category.Icon"></i>
                    </div>
                    <h4>@category.Name</h4>
                    <a asp-action="Products" asp-route-id="@category.Id" class="btn btn-info text-white">عرض المنتجات</a>
                </div>
            </div>
        </div>
    }
</div>

