
@model List<Product>

@{

}
<div class="container">
    <div class="row">
        <div class="col">
            <h1>لوحة التحكم لإضافة المنتجات</h1>
        </div>
    </div>
</div>
<div class="container mt-4">

    <div class="card">
        <div class="card-header">
            <h5>
                <i class="bi bi-plus-circle-fill"></i> اضافة منتج جديد
            </h5>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
              @Html.AntiForgeryToken()

              <div class="mb-3">
                <label class="form-label">اسم المنتج</label>
                <input type="text" name="Name" placeholder="أدخل اسم المنتج" class="form-control" />
                <span asp-validation-for="@Model.First().Name" class="text-danger"></span>
              </div>

               <div class="mb-3">
                <label class="form-label">سعر المنتج</label>
                <input type="number" name="Price" value="0" steps="1" placeholder="أدخل سعر المنتج" class="form-control" />
                <span asp-validation-for="@Model.First().Price" class="text-danger"></span>
              </div>

                <div class="mb-3">
                <label class="form-label"> الفئة</label>
                <select name="CategoryId" class="form-select" size="3">
                    @foreach(var item in ViewBag.Categories){
                        <option value="@item.Id">@item.Name</option>
                    }
                </select>
              </div>
                <div class="mb-4">
                    <label class="form-label fw-semibold">صورة المنتج المرفوعة</label>
                    <input name="ImageFile" type="file" class="form-control"/>
                    @if (Model != null && Model.Any())
                    {
                        <span asp-validation-for="@Model.First().ImageFile" class="text-danger"></span>
                    }
                </div>
              <div class="mb-3">
               
               <button class="btn btn-success px-4 fw-bload">حفظ المنتج</button>
               <a asp-action="Index" class="btn"><i>عودة</i></a>
                
              </div>
            </form>
        </div>
    </div>

</div>
 <div class="card mt-5">
        <div class="card-body">
            <table class="table">
             <thead>
                  <tr>
                    <td>#</td>
                    <td>اسم المنتج</td>
                    <td>سعر المنتج</td>
                    <td> أجراءات</td>
                    <td> الفئة</td>
                    <td> الصورة</td>
                  </tr>
             </thead>

             <tbody>
              @if(Model==null )
              {
                <tr>
                    <td>لا توجد بيانات</td>
                </tr>
              }

              else{
                @foreach(var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bload text-secandory">@item.Id</td>
                        <td class="ps-4 fw-bload text-secandory">@item.Name</td>
                        <td class="ps-4 fw-bload text-secandory">@item.Price</td>
                        <td class="ps-4 fw-bload text-secandory">@item.Categories.Name</td>
                        <td>
                            <img src="~/images/@item.Image"
                                alt="@item.Name"
                                width="70"
                                height="70"
                                class="rounded"
                                style="object-fit:cover;" />
                        </td>
                        <td> <a asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil-square text-success"></i></a></td>
                        <td> <a asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash3 text-danger"></i></a></td>
                        
                    </tr>
                }
              }
             </tbody>
            </table>
        </div>
    </div>